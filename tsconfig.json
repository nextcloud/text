{
	"extends": "@vue/tsconfig",
	"include": ["src/**/*.ts", "*.ts", "src/**/*.vue", "playwright/**/*.ts"],
	"compilerOptions": {
		"allowJs": true,
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ESNext", "DOM"],
		"allowImportingTsExtensions": true
	}
}
